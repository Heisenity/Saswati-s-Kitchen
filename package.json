{
  "name": "saswatis-kitchen",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:raw",
    "dev:raw": "next dev -p 4001",
    "dev:doppler": "doppler run -- npm run dev:raw",
    "dev:chat": "npm run dev:chat:raw",
    "dev:chat:raw": "PORT=4000 node --watch --watch-preserve-output --import tsx chat-server/src/index.ts",
    "dev:chat:doppler": "doppler run -- npm run dev:chat:raw",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:all:raw": "node scripts/dev-all.mjs",
    "dev:all:doppler": "doppler run -- npm run dev:all:raw",
    "build": "next build",
    "start": "next start -p 4001",
    "start:chat": "PORT=4000 node --import tsx chat-server/src/index.ts",
    "lint": "next lint",
    "prisma:generate": "doppler run -- prisma generate",
    "prisma:generate:raw": "prisma generate",
    "prisma:migrate": "doppler run -- prisma migrate dev",
    "prisma:migrate:raw": "prisma migrate dev",
    "prisma:seed": "doppler run -- tsx prisma/seed.ts",
    "prisma:seed:raw": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@supabase/ssr": "0.7.0",
    "@supabase/supabase-js": "2.108.2",
    "@aws-sdk/client-s3": "^3.844.0",
    "@aws-sdk/s3-request-presigner": "^3.844.0",
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^6.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "framer-motion": "^12.17.3",
    "lucide-react": "^0.525.0",
    "multer": "^2.0.2",
    "next": "^15.3.4",
    "nodemailer": "^7.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.58.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.20.3",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "postcss": "^8.5.6",
    "prisma": "^6.10.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
